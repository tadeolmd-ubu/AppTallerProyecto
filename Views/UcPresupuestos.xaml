<UserControl x:Class="AppTaller.Views.UcPresupuestos"
			     xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
			     xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			     xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			     xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			     mc:Ignorable="d"
			     Width="1004"
			     Height="661"
			     Background="#0A003A">

    <UserControl.Resources>
        <!-- Estilos Labels -->
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="GhostWhite"/>
            <Setter Property="FontFamily" Value="Montserrat"/>
        </Style>

        <!-- Estilos Base de Formulario -->
        <Style TargetType="{x:Type Control}" x:Key="BaseFormStyle">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="FontFamily" Value="Montserrat"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="DarkGray"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="{x:Null}"/>
            <Setter Property="Width" Value="252"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>

        <Style TargetType="TextBox" BasedOn="{StaticResource BaseFormStyle}"/>
        <Style TargetType="ComboBox" BasedOn="{StaticResource BaseFormStyle}">
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#1B1428"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>

    </UserControl.Resources>

    <Grid Background="#0A003A" Margin="0,0,10,0" Height="661" VerticalAlignment="Top">

        <!-- LOGO -->
        <Image Source="/Images/TRACTOR_V2.png" 
			       Width="120" 
			       Height="100" 
			       Margin="30,20,0,0" 
			       HorizontalAlignment="Left" 
			       VerticalAlignment="Top"/>

        <!-- TÍTULO -->
        <Label Content="Presupuestos" 
			       FontSize="28" 
			       FontWeight="Bold" 
			       Margin="170,30,0,0" 
			       HorizontalAlignment="Left"
			       VerticalAlignment="Top"
			       Foreground="White"/>

        <Label Content="Completa el formulario para registrar o editar un presupuesto"
			       Foreground="#FF81969C" 
			       FontSize="10" 
			       Margin="170,65,0,0"
			       HorizontalAlignment="Left"
			       VerticalAlignment="Top"/>

        <!-- CONTENEDOR PRINCIPAL -->
        <Grid Margin="30,120,30,80">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- COLUMNA IZQUIERDA - DATOS DEL PRESUPUESTO -->
            <StackPanel Grid.Column="0" Orientation="Vertical">

                <Label Content="ID Presupuesto"/>
                <TextBox x:Name="txtIdPresupuesto" 
						     Width="252" 
						     IsReadOnly="True"
						     Background="#1B1428"
						     Foreground="White"
						     BorderBrush="DarkGray"
						     BorderThickness="1"
						     Height="28"
						     Margin="0,0,0,15"/>

                

                <Label Content="Cliente"/>
                <ComboBox x:Name="cmbCliente" Width="252" Foreground="Black" SelectedIndex="-1"/>

                <Label Content="Nota"/>
                <TextBox x:Name="txtNota" 
						     Width="252"
						     Height="80" 
						     TextWrapping="Wrap" 
						     AcceptsReturn="True"
						     VerticalAlignment="Top"
						     VerticalContentAlignment="Top"
						     Padding="5"
						     Background="{x:Null}"
						     Foreground="White"
						     BorderBrush="DarkGray"
						     BorderThickness="0,0,0,2"
						     Margin="0,0,0,15"/>

                <Label Content="Estatus"/>
                <CheckBox x:Name="chkEstatus" 
						      Content="Activo" 
						      Foreground="White"
						      FontFamily="Montserrat"
						      FontSize="13"
						      Margin="0,0,0,15"/>

            </StackPanel>

            <!-- COLUMNA DERECHA - DETALLE DEL PRESUPUESTO -->
            <StackPanel Grid.Column="1" Orientation="Vertical" Margin="30,0,0,0">

                <Label Content="Detalle del Presupuesto" 
					       FontSize="16" 
					       FontWeight="SemiBold" 
					       Margin="0,0,0,10"
					       Foreground="White"/>

                <!-- Sección Buscar y Agregar Producto -->
                <Border Background="#1B1428" 
						    BorderBrush="DarkGray" 
						    BorderThickness="1" 
						    CornerRadius="5"
						    Padding="10"
						    Margin="0,0,0,15">
                    <StackPanel Orientation="Horizontal">
                        <Label Content="Id del producto:" 
							       Foreground="White" 
							       VerticalAlignment="Center"
							       Margin="0,0,5,0"
							       Width="98"/>
                        <TextBox x:Name="txtIdProducto" 
								     Width="205" 
								     Height="30"
                                     IsReadOnly="True"
								     Background="#0A003A"
								     Foreground="White"
								     BorderBrush="DarkGray"
								     BorderThickness="1"
								     VerticalContentAlignment="Center"
								     FontFamily="Montserrat"
								     Padding="5,0"
								     Margin="0,0,10,0"/>
                        <Button x:Name="btnBuscarProducto" 
								    Content="Buscar Producto" 
								    Width="130" 
								    Height="30"
								    Background="#2C2545" 
								    Foreground="White"
								    FontFamily="Montserrat"
								    FontSize="12"
								    FontWeight="SemiBold"
								    BorderThickness="0"
								    Cursor="Hand" Click="btnBuscarProducto_Click_1"/>
                    </StackPanel>
                </Border>


                <!-- DataGrid de Detalles -->
                <Border BorderBrush="DarkGray" BorderThickness="1" Height="250" Margin="0,0,0,15">
                    <DataGrid x:Name="dtgDetalles"
                  Background="#1B1428"
                  Foreground="White"
                  BorderThickness="0"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserResizeRows="False"
                  CanUserReorderColumns="False"
                  HeadersVisibility="Column"
                  GridLinesVisibility="None"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  SelectionChanged="dtgDetalles_SelectionChanged"
                  IsSynchronizedWithCurrentItem="False">

                        <!-- Estilo de las columnas del header -->
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#2C2545"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="FontFamily" Value="Montserrat"/>
                                <Setter Property="Padding" Value="5"/>
                                <Setter Property="BorderBrush" Value="DarkGray"/>
                                <Setter Property="BorderThickness" Value="0,0,1,1"/>
                                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>

                        <!-- Estilo de las filas -->
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="#1B1428"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#2C2545"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>

                        <!-- Estilo de las celdas -->
                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="FontFamily" Value="Montserrat"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#2C2545"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.CellStyle>

                        <DataGrid.Columns>
                            <!-- ID Producto -->
                            <DataGridTextColumn Header="ID" Width="30" Binding="{Binding idInventario}" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Padding" Value="5,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <!-- Nombre -->
                            <!--<DataGridTextColumn Header="Nombre" Width="150" Binding="{Binding Producto.nombre}" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Padding" Value="5,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>-->

                            <!-- Cantidad con botones -->
                            <DataGridTemplateColumn Header="Cantidad" Width="150">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <Button Content="-" 
                                        Width="30" 
                                        Height="25"
                                        Background="#8B2C4E" 
                                        Foreground="White"
                                        FontWeight="Bold"
                                        FontSize="16"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        Tag="{Binding}"
                                        Margin="0,0,5,0"
                                        Click="btnDisminuir_Click"/>

                                            <TextBlock Text="{Binding cantidad}" 
                                           Width="40"
                                           Height="25"
                                           Background="#0A003A"
                                           Foreground="White"
                                           TextAlignment="Center"
                                           VerticalAlignment="Center"
                                           Padding="0,3,0,0"
                                           FontWeight="SemiBold"
                                           Margin="0,0,5,0"/>

                                            <Button Content="+" 
                                        Width="30" 
                                        Height="25"
                                        Background="#27C2FF" 
                                        Foreground="#0A003A"
                                        FontWeight="Bold"
                                        FontSize="16"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        Tag="{Binding}"
                                        Margin="0,0,5,0"
                                        Click="btnAumentar_Click"/>

                                            <Button Content="X" 
                                        Width="30" 
                                        Height="25"
                                        Background="#8B2C4E" 
                                        Foreground="White"
                                        FontWeight="Bold"
                                        FontSize="14"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        Tag="{Binding}"
                                        Click="btnEliminar_Click"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Precio Unitario -->
                            <DataGridTextColumn Header="Precio Unit." Width="90" Binding="{Binding precioUnitario, StringFormat={}{0:C}}" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextAlignment" Value="Right"/>
                                        <Setter Property="Padding" Value="5,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <!-- Importe -->
                            <DataGridTextColumn Header="Importe" Width="100" Binding="{Binding importe, StringFormat={}{0:C}}" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextAlignment" Value="Right"/>
                                        <Setter Property="Padding" Value="5,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <!-- IVA -->
                            <DataGridTextColumn Header="IVA" Width="80" Binding="{Binding iva, StringFormat={}{0:C}}" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextAlignment" Value="Right"/>
                                        <Setter Property="Padding" Value="5,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <!-- SECCIÓN TOTAL -->
                <StackPanel Orientation="Vertical">

                    <!-- Checkbox IVA -->
                    <CheckBox x:Name="chkAplicarIVA" 
							      Content="Aplicar IVA (16%)" 
							      Foreground="White"
							      FontFamily="Montserrat"
							      FontSize="13"
							      Margin="0,0,0,10"
							      HorizontalAlignment="Right"/>

                    <!-- Total -->
                    <StackPanel Orientation="Horizontal" 
								    HorizontalAlignment="Right">
                        <Label Content="TOTAL:" 
							       FontSize="18"
							       FontWeight="Bold"
							       Foreground="White"
							       Margin="0,0,15,0"/>
                        <TextBox x:Name="txtTotal" 
								     Width="180" 
								     Height="35"
								     IsReadOnly="True"
								     FontSize="18"
								     FontWeight="Bold"
								     Background="#1B1428"
								     Foreground="White"
								     TextAlignment="Right"
								     VerticalContentAlignment="Center"
								     BorderThickness="2"
								     BorderBrush="#27C2FF"
								     Padding="10,0" TextChanged="txtTotal_TextChanged"/>
                    </StackPanel>
                </StackPanel>

            </StackPanel>

        </Grid>

        <!-- BOTONES INFERIORES -->
        <StackPanel Orientation="Horizontal" 
					    Margin="30,0,0,30" 
					    HorizontalAlignment="Left"
					    VerticalAlignment="Bottom">

            <Button x:Name="btnBuscar" 
					    Content="Buscar" 
					    Width="100" 
					    Height="35"
					    Background="#2C2545" 
					    Foreground="White"
					    FontFamily="Montserrat"
					    FontWeight="SemiBold"
					    BorderThickness="0"
					    Cursor="Hand"
					    Margin="0,0,10,0" 
					    Click="btnBuscar_Click"/>

            <Button x:Name="btnEliminarPresupuesto" 
					    Content="Eliminar" 
					    Width="100" 
					    Height="35"
					    Background="#8B2C4E" 
					    Foreground="White"
					    FontFamily="Montserrat"
					    FontWeight="SemiBold"
					    BorderThickness="0"
					    Cursor="Hand"
					    Click="btnEliminarPresupuesto_Click"/>
        </StackPanel>

        <Button x:Name="btnGuardar"
				    Content="Guardar"
				    Width="130"
				    Height="45"
				    FontSize="16"
				    FontWeight="Bold"
				    Margin="0,0,30,30"
				    HorizontalAlignment="Right"
				    VerticalAlignment="Bottom"
				    Background="#2C2545"
				    Foreground="White"
				    FontFamily="Montserrat"
				    BorderThickness="0"
				    Cursor="Hand"
				    Click="btnGuardar_Click"/>

    </Grid>
</UserControl>