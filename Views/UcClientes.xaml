<UserControl x:Class="AppTaller.Views.UcClientes"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AppTaller.Views"
             mc:Ignorable="d" 
             Width="800"
             Height="550"
             Background="#0A003A">

    <UserControl.Resources>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="GhostWhite"/>
            <Setter Property="FontFamily" Value="Montserrat"/>
        </Style>

        <Style TargetType="{x:Type Control}" x:Key="BaseFormStyle">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="FontFamily" Value="Montserrat"/>
            <Setter Property="Foreground" Value="White"/>

            <Setter Property="BorderBrush" Value="DarkGray"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="{x:Null}"/>
            <Setter Property="Width" Value="252"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>

        <Style TargetType="TextBox" BasedOn="{StaticResource BaseFormStyle}"/>

        <Style TargetType="PasswordBox" BasedOn="{StaticResource BaseFormStyle}">
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="ComboBox" BasedOn="{StaticResource BaseFormStyle}">
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#1B1428"/>
            <Setter Property="Margin" Value="0"/>
        </Style>

    </UserControl.Resources>

    <Grid Background="#0A003A" HorizontalAlignment="Left" Width="800">
        <StackPanel Orientation="Horizontal" Margin="0,0,510,404" Height="160" VerticalAlignment="Bottom" HorizontalAlignment="Right" Width="269">
            <Image Source="/Images/TRACTOR_V2.png" Stretch="Fill" Height="60" Width="60" />
            <StackPanel Height="95" Width="606"/>
        </StackPanel>
        <Label Content="Id del cliente" HorizontalAlignment="Left" Margin="41,134,0,0" VerticalAlignment="Top" FontSize="14"/>
        <TextBox x:Name="txtIdCliente" HorizontalAlignment="Left" Margin="136,131,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="37"/>
        <Label Content="Nombre del cliente" HorizontalAlignment="Left" Margin="41,190,0,0" VerticalAlignment="Top" FontSize="14"/>
        <TextBox x:Name="txtNombreCliente" HorizontalAlignment="Left" Margin="41,214,0,0" TextWrapping="Wrap" Text="&#xA;" VerticalAlignment="Top" Width="244"/>
        <Label Content="Telefono" HorizontalAlignment="Left" Margin="41,257,0,0" VerticalAlignment="Top" FontSize="14"/>
        <TextBox x:Name="txtTelefono" HorizontalAlignment="Left" Margin="41,281,0,0" TextWrapping="Wrap" Text="&#xA;" VerticalAlignment="Top" Width="244"/>
        <Label Content="Direccion" HorizontalAlignment="Left" Margin="578,131,0,0" VerticalAlignment="Top" FontSize="20" />
        <TextBox x:Name="txtCiudad" HorizontalAlignment="Left" Margin="482,236,0,0" TextWrapping="Wrap" Text="&#xA;" VerticalAlignment="Top" Width="120"/>
        <Label Content="Ciudad" HorizontalAlignment="Left" Margin="482,212,0,0" VerticalAlignment="Top" FontSize="14"/>
        <TextBox x:Name="txtColonia" HorizontalAlignment="Left" Margin="644,236,0,0" TextWrapping="Wrap" Text="&#xA;" VerticalAlignment="Top" Width="120"/>
        <Label Content="Colonia" HorizontalAlignment="Left" Margin="644,212,0,0" VerticalAlignment="Top" FontSize="14"/>
        <TextBox x:Name="txtCodigoPostal" HorizontalAlignment="Left" Margin="645,308,0,0" TextWrapping="Wrap" Text="&#xA;" VerticalAlignment="Top" Width="120"/>
        <Label Content="Codigo postal" HorizontalAlignment="Left" Margin="645,284,0,0" VerticalAlignment="Top" FontSize="14"/>
        <TextBox x:Name="txtCalle" HorizontalAlignment="Left" Margin="482,308,0,0" TextWrapping="Wrap" Text="&#xA;" VerticalAlignment="Top" Width="120"/>
        <Label Content="Calle" HorizontalAlignment="Left" Margin="482,284,0,0" VerticalAlignment="Top" FontSize="14"/>
        <TextBox x:Name="txtNumeroCasa" HorizontalAlignment="Left" Margin="482,372,0,0" TextWrapping="Wrap" Text="&#xA;" VerticalAlignment="Top" Width="120"/>
        <Label Content="Numero de Casa" HorizontalAlignment="Left" Margin="482,348,0,0" VerticalAlignment="Top" FontSize="14"/>

        <Button x:Name="btnGuardar"         
                Style ="{StaticResource controlBoton}"
                Click="btnGuardar_Click" 
                Content="Guardar" 
                Height="25"
                Width="70"
                FontSize="14"
                Margin="687,389,43,136">

        </Button>
        <CheckBox x:Name="chkEstatus" Content="Vigente" HorizontalAlignment="Left" Margin="41,349,0,0" VerticalAlignment="Top" Foreground="White"/>
        <Label Content="Estatus" HorizontalAlignment="Left" Margin="41,320,0,0" VerticalAlignment="Top"/>
        <Label Content="Clientes" FontSize="28" FontWeight="Bold" Padding="0" Foreground="{StaticResource titleColor1}" Margin="80,38,114,479"/>
        <Label Content="Completa el formulario para crear el usuario" Foreground="#FF81969C" FontSize="10" Padding="0,2,0,0" Margin="80,71,114,465"/>
        <TextBox x:Name="txtIdDireccion" HorizontalAlignment="Left" Margin="482,442,0,0" TextWrapping="Wrap" Text="&#xA;" VerticalAlignment="Top" Width="120"/>
        <Label Content="Id direccion" HorizontalAlignment="Left" Margin="482,418,0,0" VerticalAlignment="Top" FontSize="14"/>
    </Grid>
</UserControl>
