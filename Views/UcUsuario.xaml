<UserControl x:Class="AppTaller.Views.UcUsuario"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
             
             Background="#060531" >
    <UserControl.Resources>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="GhostWhite"/>
            <Setter Property="FontFamily" Value="Montserrat"/>
        </Style>

        <Style TargetType="{x:Type Control}" x:Key="BaseFormStyle">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="FontFamily" Value="Montserrat"/>
            <Setter Property="Foreground" Value="White"/>

            <Setter Property="BorderBrush" Value="DarkGray"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="{x:Null}"/>
            <Setter Property="Width" Value="252"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>

        <Style TargetType="TextBox" BasedOn="{StaticResource BaseFormStyle}"/>

        <Style TargetType="PasswordBox" BasedOn="{StaticResource BaseFormStyle}">
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="ComboBox" BasedOn="{StaticResource BaseFormStyle}">
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#1B1428"/>
            <Setter Property="Margin" Value="0"/>
        </Style>

    </UserControl.Resources>

    <Grid MouseDown="Grid_MouseDown" Background="#060531" Height="524" Width="819">

        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="10,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Image Source="/Images/TRACTOR_V2.png" Stretch="Fill" Height="60" Width="60" Margin="0,0,15,0"/>
                    <StackPanel VerticalAlignment="Center">
                        <Label Content="Crear Usuario" FontSize="28" FontWeight="Bold" Padding="0"/>
                        <Label Content="Completa el formulario para crear el usuario" Foreground="#FF81969C" FontSize="10" Padding="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Orientation="Vertical" Margin="10,84,281,-84" Grid.Column="1" >
                    <Label Content="Número de usuario" FontSize="14" Padding="0" Width="122"/>
                    <TextBox x:Name="txtId" Width="112" />
                </StackPanel>

            </Grid>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300"/>
                    <ColumnDefinition Width="300"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,20,0">
                    <Label Content="Nombre de Usuario" FontSize="14" Padding="0" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtNombre"/>

                    <Label Content="Correo electrónico" FontSize="14" Padding="0" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtCorreo"/>

                    <Label Content="Contraseña" FontSize="14" Padding="0" Margin="0,0,0,5"/>
                    <PasswordBox x:Name="txtContrasena"/>

                    <Label Content="Confirmar Contraseña" FontSize="14" Padding="0" Margin="0,0,0,5"/>
                    <PasswordBox x:Name="txtContrasena2" Margin="0,0,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="199,0,-149,0">
                    <Label Content="Teléfono del Usuario" FontSize="14" Padding="0" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtTelefono"/>

                    <Label Content="Estatus" FontSize="14" Padding="0" Margin="0,0,0,5"/>
                    <CheckBox x:Name="estatus" Content="Vigente" Foreground="White" FontFamily="Montserrat" Margin="0,5,0,20"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <Label Content="Id del rol" FontSize="14" Padding="0" Margin="0,0,0,5"/>
                            <ComboBox x:Name="idRol" DisplayMemberPath="Id" SelectedValuePath="Id"/>
                        </StackPanel>

                        <Button x:Name="btnBuscar" Grid.Column="1" VerticalAlignment="Bottom" Click="btnBuscar_Click"
                                Background="Transparent" BorderThickness="0" Height="35" Width="35" Margin="5,0,0,0">
                            <Image Source="/Images/buscar.png" Stretch="Uniform" Height="25" Width="25"/>
                        </Button>

                        <Button x:Name="btnBorrar" Grid.Column="2" VerticalAlignment="Bottom" Click="btnBorrar_Click"
                                Background="Transparent" BorderThickness="0" Height="35" Width="35" Margin="5,0,0,0">
                            <Image Source="/Images/borrar.png" Stretch="Uniform" Height="25" Width="25"/>
                        </Button>
                    </Grid>
                </StackPanel>

            </Grid>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,30,0,0">
                <Button x:Name="btnGuardar" Content="GUARDAR" Click="Button_Click"
                        Background="#FFD6A04A" Foreground="GhostWhite" FontWeight="ExtraBold"
                        Width="120" Height="35" Margin="0,0,15,0"/>
                <Button Content="CANCELAR" Click="Button_Click_1"
                        Background="#FFD6504A" Foreground="GhostWhite" FontWeight="ExtraBold"
                        Width="120" Height="35"/>
            </StackPanel>

        </Grid>
    </Grid>
</UserControl>