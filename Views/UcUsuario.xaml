<UserControl x:Class="AppTaller.Views.UcUsuario"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
             Width="1004"
             Height="661"
             Background="#0A003A">

    <UserControl.Resources>
        <!-- Estilos Labels -->
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="GhostWhite"/>
            <Setter Property="FontFamily" Value="Montserrat"/>
        </Style>

        <!-- Estilos Base de Formulario -->
        <Style TargetType="{x:Type Control}" x:Key="BaseFormStyle">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="FontFamily" Value="Montserrat"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="DarkGray"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="{x:Null}"/>
            <Setter Property="Width" Value="252"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>

        <Style TargetType="TextBox" BasedOn="{StaticResource BaseFormStyle}"/>

        <Style TargetType="PasswordBox" BasedOn="{StaticResource BaseFormStyle}">
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="ComboBox" BasedOn="{StaticResource BaseFormStyle}">
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#1B1428"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>

    </UserControl.Resources>

    <Grid MouseDown="Grid_MouseDown" Background="#0A003A" Margin="0,0,10,0">

        <!-- LOGO -->
        <Image Source="/Images/TRACTOR_V2.png" 
               Width="120" 
               Height="100" 
               Margin="30,20,0,0" 
               HorizontalAlignment="Left" 
               VerticalAlignment="Top"/>

        <!-- TÍTULO -->
        <Label Content="Crear Usuario" 
               FontSize="28" 
               FontWeight="Bold" 
               Margin="170,30,0,0" 
               HorizontalAlignment="Left"
               VerticalAlignment="Top"
               Foreground="White"/>

        <Label Content="Completa el formulario para crear el usuario"
               Foreground="#FF81969C" 
               FontSize="10" 
               Margin="170,65,0,0"
               HorizontalAlignment="Left"
               VerticalAlignment="Top"/>

        <!-- CONTENEDOR PRINCIPAL -->
        <Grid Margin="30,120,30,80">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- COLUMNA IZQUIERDA - DATOS BÁSICOS -->
            <StackPanel Grid.Column="0" Orientation="Vertical">

                <Label Content="Número de Usuario"/>
                <TextBox x:Name="txtId" 
                         Width="252" 
                         IsReadOnly="True"
                         Background="#1B1428"
                         Foreground="White"
                         BorderBrush="DarkGray"
                         BorderThickness="1"
                         Height="28"
                         Margin="0,0,0,15"/>

                <Label Content="Nombre de Usuario"/>
                <TextBox x:Name="txtNombre" Width="252"/>

                <Label Content="Correo Electrónico"/>
                <TextBox x:Name="txtCorreo" Width="252"/>

                <Label Content="Contraseña"/>
                <PasswordBox x:Name="txtContrasena" Width="252"/>

                <Label Content="Confirmar Contraseña"/>
                <PasswordBox x:Name="txtContrasena2" Width="252"/>

            </StackPanel>

            <!-- COLUMNA CENTRAL - DATOS ADICIONALES -->
            <StackPanel Grid.Column="1" Orientation="Vertical" Margin="30,0,0,0">

                <Label Content="Teléfono del Usuario"/>
                <TextBox x:Name="txtTelefono" Width="252"/>

                <Label Content="ID del Rol"/>
                <ComboBox x:Name="cmbIdRol" 
                          DisplayMemberPath="Id" 
                          SelectedValuePath="Id" 
                          Foreground="Black" 
                          Width="252" 
                          SelectedIndex="-1"/>

                <Label Content="Estatus"/>
                <CheckBox x:Name="estatus" 
                          Content="Vigente" 
                          Foreground="White"
                          FontFamily="Montserrat"
                          FontSize="13"
                          Margin="0,0,0,15"/>

                <!-- Sección con botones Buscar y Borrar -->
                <Border Background="#1B1428" 
                        BorderBrush="DarkGray" 
                        BorderThickness="1" 
                        CornerRadius="5"
                        Padding="10"
                        Margin="0,20,0,15"
                        Width="252"
                        HorizontalAlignment="Left">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button x:Name="btnBuscar" 
                                Width="105" 
                                Height="35"
                                Background="#2C2545" 
                                Foreground="White"
                                FontFamily="Montserrat"
                                FontSize="12"
                                FontWeight="SemiBold"
                                BorderThickness="0"
                                Cursor="Hand"
                                Margin="0,0,10,0"
                                Click="btnBuscar_Click">
                            <StackPanel Orientation="Horizontal">
                                <Image Source="/Images/buscar.png" 
                                       Stretch="Uniform" 
                                       Height="18" 
                                       Width="18" 
                                       Margin="0,0,5,0"/>
                                <TextBlock Text="Buscar" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="btnBorrar" 
                                Width="105" 
                                Height="35"
                                Background="#8B2C4E" 
                                Foreground="White"
                                FontFamily="Montserrat"
                                FontSize="12"
                                FontWeight="SemiBold"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="btnBorrar_Click">
                            <StackPanel Orientation="Horizontal">
                                <Image Source="/Images/borrar.png" 
                                       Stretch="Uniform" 
                                       Height="18" 
                                       Width="18" 
                                       Margin="0,0,5,0"/>
                                <TextBlock Text="Borrar" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

            </StackPanel>

        </Grid>

        <!-- BOTONES INFERIORES -->
        <StackPanel Orientation="Horizontal" 
                    Margin="0,0,30,30" 
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom">

            <Button x:Name="btnGuardar"
                    Content="Guardar"
                    Width="130"
                    Height="45"
                    FontSize="16"
                    FontWeight="Bold"
                    Background="#2C2545"
                    Foreground="White"
                    FontFamily="Montserrat"
                    BorderThickness="0"
                    Cursor="Hand"
                    Margin="0,0,10,0"
                    Click="Button_Click"/>

            <Button Content="Cancelar"
                    Width="130"
                    Height="45"
                    FontSize="16"
                    FontWeight="Bold"
                    Background="#8B2C4E"
                    Foreground="White"
                    FontFamily="Montserrat"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="Button_Click_1"/>
        </StackPanel>

    </Grid>
</UserControl>