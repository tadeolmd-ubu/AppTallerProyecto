<Window x:Class="AppTaller.Views.FrmMenuPrincipal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AppTaller.Views"
        xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
        mc:Ignorable="d"
        Title="FrmMenuPrincipal" Height="700" Width="1300"
        WindowStyle="None"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStartupLocation="CenterScreen"
        MouseDown="Window_MouseDown">

    <Border
           CornerRadius="10"
           BorderBrush="DarkSlateGray"
           BorderThickness="1">


        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#060531" Offset="0"/>
                <GradientStop Color="#1B1428" Offset="0.75"/>
            </LinearGradientBrush>
        </Border.Background>

        <Grid>
            <Grid.ColumnDefinitions>
                <!--menu-->
                <ColumnDefinition Width="170"/>
                <!--contenidos-->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!--Menu de navegacion-->
            <Border CornerRadius="10,0,0,10"
                    Grid.Column="0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1, 0.7">
                        <GradientStop Color="{StaticResource secondaryBackColor1}" Offset="0" />
                        <GradientStop Color="{StaticResource secondaryBackColor2}" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
            <StackPanel>

                <StackPanel Orientation="Horizontal"
                            Height="35"
                            Margin="15,25,0,40">

                    <Image Source="/Images/bomba.png"/>
                    <TextBlock Text="Laboratorio Diesel"
                               FontSize="14"
                               FontFamily="montserrat"
                               Foreground="White"
                               FontWeight="Medium"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </StackPanel>
            
            <!--botones de la barra de la izqiuerda-->
            <RadioButton Style="{StaticResource menuBoton}"
                         Tag="{StaticResource color1}">
                <StackPanel Orientation="Horizontal">
                    
                </StackPanel>
                
            </RadioButton>
            
            
            <!--Donde van a ir los forms-->
            <Border CornerRadius="0,10,10,0"
        Grid.Column="1" MouseDown="Border_MouseDown">
                <Border.Background>
                    <LinearGradientBrush StartPoint="1,1" EndPoint="0,0">
                        <GradientStop Color="{StaticResource primaryBackColor1}" Offset="0" />
                        <GradientStop Color="{StaticResource primaryBackColor1}" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

        </Grid>



    </Border>


</Window>
