<Window x:Class="AppTaller.Views.FrmLogin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AppTaller.Views"
        mc:Ignorable="d"
        Title="FrmLogin" 
        Height="650" 
        Width="450"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        AllowsTransparency="True"
        MouseDown="Window_MouseDown">

    <Border CornerRadius="20"
            BorderBrush="#2C2545"
            BorderThickness="3"
            Background="#0A003A">

        <Grid Cursor="Hand" MouseDown="Grid_MouseDown">
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <!-- Barra de título -->
                <RowDefinition Height="*"/>
                <!-- Contenido -->
            </Grid.RowDefinitions>

            <!-- BARRA DE TÍTULO -->
            <Grid Grid.Row="0" Background="#1B1428">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Login"
                           Foreground="White"
                           FontSize="14"
                           FontWeight="SemiBold"
                           FontFamily="Montserrat"
                           Grid.Column="0"
                           VerticalAlignment="Center"
                           Margin="20,0,0,0"/>

                <!-- Botones de control de ventana -->
                <StackPanel Grid.Column="1" 
                            Orientation="Horizontal" 
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Margin="0,0,10,0">

                    <Button x:Name="btnMinimizar"
                            Width="30"
                            Height="30"
                            Margin="0,0,5,0"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="btnMinimizar_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#2C2545"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="5">
                                    <TextBlock Text="−"
                                               Foreground="White"
                                               FontSize="20"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Margin="0,-3,0,0"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button x:Name="btnCerrar"
                            Width="30"
                            Height="30"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="btnCerrar_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#8B2C4E"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="5">
                                    <TextBlock Text="✕"
                                               Foreground="White"
                                               FontSize="16"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- CONTENIDO DEL LOGIN -->
            <StackPanel Grid.Row="1"
                        Width="320"
                        Orientation="Vertical"
                        VerticalAlignment="Center"
                        Margin="0,0,0,20">

                <!-- Logo -->
                <Image Source="/Images/TRACTOR_V2.png" 
                       Stretch="Uniform" 
                       Height="120" 
                       Width="120"
                       Margin="0,0,0,20"/>

                <!-- Título -->
                <TextBlock Text="Laboratorio"
                           Foreground="White"
                           FontSize="28"
                           FontWeight="Bold"
                           FontFamily="Montserrat"
                           TextAlignment="Center"
                           Margin="0,0,0,5"/>

                <TextBlock Text="Diesel de Guasave"
                           Foreground="#FF81969C"
                           FontSize="16"
                           FontWeight="Medium"
                           FontFamily="Montserrat"
                           TextAlignment="Center"
                           Margin="0,0,0,40"/>

                <!-- Campo Usuario -->
                <TextBlock Text="Usuario"
                           Foreground="White"
                           FontSize="14"
                           FontWeight="Medium"
                           FontFamily="Montserrat"
                           Margin="0,0,0,8"/>

                <Border Background="#1B1428"
                        BorderBrush="DarkGray"
                        BorderThickness="1"
                        CornerRadius="5"
                        Height="45"
                        Margin="0,0,0,20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="45"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Image Source="/Images/icon_user.png"
                               Grid.Column="0"
                               Width="20"
                               Height="20"
                               Margin="12,0,0,0"
                               HorizontalAlignment="Left"/>

                        <TextBox x:Name="txtUsuario"
                                 Grid.Column="1"
                                 FontSize="13"
                                 FontWeight="Medium"
                                 FontFamily="Montserrat"
                                 Foreground="White"
                                 CaretBrush="White"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 VerticalContentAlignment="Center"
                                 Padding="5,0,10,0"/>
                    </Grid>
                </Border>

                <!-- Campo Contraseña -->
                <TextBlock Text="Contraseña"
                           Foreground="White"
                           FontSize="14"
                           FontWeight="Medium"
                           FontFamily="Montserrat"
                           Margin="0,0,0,8"/>

                <Border Background="#1B1428"
                        BorderBrush="DarkGray"
                        BorderThickness="1"
                        CornerRadius="5"
                        Height="45"
                        Margin="0,0,0,15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="45"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="45"/>
                        </Grid.ColumnDefinitions>

                        <Image Source="/Images/icon_password.png"
                               Grid.Column="0"
                               Width="20"
                               Height="20"
                               Margin="12,0,0,0"
                               HorizontalAlignment="Left"/>

                        <PasswordBox x:Name="txtContrasena"
                                     Grid.Column="1"
                                     FontSize="13"
                                     FontWeight="Medium"
                                     FontFamily="Montserrat"
                                     Foreground="White"
                                     CaretBrush="White"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     VerticalContentAlignment="Center"
                                     Padding="5,0,5,0"/>

                        <StackPanel Grid.Column="2" 
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <Image Source="/Images/icon_mostrar.png"
                                   Width="20"
                                   Height="20"
                                   Margin="0,0,0,0"
                                   Opacity="0.6"
                                   Cursor="Hand"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Texto de registro -->
                <TextBlock Text="¿Aún no tienes una cuenta? ¡Regístrate!"
                           Foreground="#FF81969C"
                           FontSize="11"
                           FontFamily="Montserrat"
                           TextAlignment="Center"
                           Margin="0,0,0,30"/>

                <!-- Botón Login -->
                <Button x:Name="btnLogin"
                        Height="50"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="btnLogin_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#2C2545"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#3E3556"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border CornerRadius="10"
                                    Background="{TemplateBinding Background}">
                                <TextBlock Text="Iniciar Sesión"
                                           Foreground="{TemplateBinding Foreground}"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           FontFamily="Montserrat"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

            </StackPanel>

        </Grid>
    </Border>

</Window>