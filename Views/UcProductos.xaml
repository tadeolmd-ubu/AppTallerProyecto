<UserControl x:Class="AppTaller.Views.UcProductos"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AppTaller.Views"
             mc:Ignorable="d" 
             Width="800"
             Height="600"
             Background="#0A003A">

    <UserControl.Resources>
        <!-- Estilos Labels -->
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="GhostWhite"/>
            <Setter Property="FontFamily" Value="Montserrat"/>
        </Style>

        <!-- Estilos Base de Formulario -->
        <Style TargetType="{x:Type Control}" x:Key="BaseFormStyle">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="FontFamily" Value="Montserrat"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="DarkGray"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="{x:Null}"/>
            <Setter Property="Width" Value="252"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>

        <Style TargetType="TextBox" BasedOn="{StaticResource BaseFormStyle}"/>
        <Style TargetType="PasswordBox" BasedOn="{StaticResource BaseFormStyle}">
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="ComboBox" BasedOn="{StaticResource BaseFormStyle}">
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#1B1428"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Foreground" Value="Black"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="#0A003A" HorizontalAlignment="Left" Width="800">

        <!-- Imagen -->
        <StackPanel Orientation="Horizontal" Margin="0,0,511,455" Height="160" VerticalAlignment="Bottom" HorizontalAlignment="Right" Width="269">
            <Image Source="/Images/TRACTOR_V2.png" Stretch="Fill" Height="60" Width="60" />
            <StackPanel Height="95" Width="606"/>
        </StackPanel>

        <!-- Título -->
        <Label Content="Productos" FontSize="28" FontWeight="Bold" Padding="0" Foreground="{StaticResource titleColor1}" Margin="80,38,114,479"/>
        <Label Content="Completa el formulario para registrar o editar un producto" Foreground="#FF81969C" FontSize="10" Padding="0,2,0,0" Margin="80,71,114,465"/>

        <!-- COLUMNA IZQUIERDA -->
        <Label Content="Id del producto" HorizontalAlignment="Left" Margin="41,134,0,0" VerticalAlignment="Top" FontSize="14"/>
        <TextBox x:Name="txtIdProducto" HorizontalAlignment="Left" Margin="180,131,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="80" IsReadOnly="True"/>

        <Label Content="Nombre del producto" HorizontalAlignment="Left" Margin="41,170,0,0" VerticalAlignment="Top" FontSize="14"/>
        <TextBox x:Name="txtNombreProducto" HorizontalAlignment="Left" Margin="41,194,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="244"/>

        <Label Content="Precio" HorizontalAlignment="Left" Margin="41,227,0,0" VerticalAlignment="Top" FontSize="14"/>
        <TextBox x:Name="txtPrecio" HorizontalAlignment="Left" Margin="41,251,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="244"/>

        <Label Content="Estatus" HorizontalAlignment="Left" Margin="41,290,0,0" VerticalAlignment="Top"/>
        <CheckBox x:Name="chkEstatus" Content="Activo" HorizontalAlignment="Left" Margin="41,319,0,0" VerticalAlignment="Top" Foreground="White"/>

        <!-- BOTONES IZQUIERDA -->
        <Button x:Name="btnBuscar" 
                Click="btnBuscar_Click" 
                Content="Buscar" 
                HorizontalAlignment="Left" 
                Margin="41,370,0,0" 
                VerticalAlignment="Top"
                Height="30"
                Width="90"
                Background="#2C2545"
                Foreground="White"
                BorderBrush="#3E3556"
                FontFamily="Montserrat"
                FontSize="13"
                Cursor="Hand"/>

        <Button x:Name="btnEliminar" 
                Click="btnEliminar_Click" 
                Content="Borrar" 
                HorizontalAlignment="Left" 
                Margin="145,370,0,0" 
                VerticalAlignment="Top"
                Height="30"
                Width="90"
                Background="#2C2545"
                Foreground="White"
                BorderBrush="#3E3556"
                FontFamily="Montserrat"
                FontSize="13"
                Cursor="Hand"/>

        <!-- COLUMNA DERECHA -->
        <Label Content="Detalles del Producto" HorizontalAlignment="Left" Margin="450,131,0,0" VerticalAlignment="Top" FontSize="20" FontWeight="Bold"/>

        <Label Content="Marca" HorizontalAlignment="Left" Margin="450,170,0,0" VerticalAlignment="Top" FontSize="14"/>
        <ComboBox x:Name="cmbMarca" HorizontalAlignment="Left" Margin="450,194,0,0" VerticalAlignment="Top" Width="140"
                  />

        <Label Content="Tipo de producto" HorizontalAlignment="Left" Margin="620,170,0,0" VerticalAlignment="Top" FontSize="14"/>
        <ComboBox x:Name="cmbTipoProducto" HorizontalAlignment="Left" Margin="620,194,0,0" VerticalAlignment="Top" Width="140"
                  />

        <Label Content="Fecha creación" HorizontalAlignment="Left" Margin="450,227,0,0" VerticalAlignment="Top" FontSize="14"/>
        <TextBox x:Name="txtFechaCreacion" HorizontalAlignment="Left" Margin="450,251,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="140" IsReadOnly="True"/>

        <Label Content="Fecha actualización" HorizontalAlignment="Left" Margin="620,227,0,0" VerticalAlignment="Top" FontSize="14"/>
        <TextBox x:Name="txtFechaActualizacion" HorizontalAlignment="Left" Margin="620,251,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="140" IsReadOnly="True"/>

        <!-- BOTON GUARDAR -->
        <Button x:Name="btnGuardar"         
                Style="{StaticResource controlBoton}"
                Click="btnGuardar_Click" 
                Content="Guardar" 
                Height="35"
                Width="100"
                FontSize="14"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="660,370,0,0"/>

    </Grid>
</UserControl>
