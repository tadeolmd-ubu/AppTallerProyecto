<UserControl x:Class="AppTaller.Views.UcProductos"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AppTaller.Views"
             mc:Ignorable="d" 
             Width="1004"
             Height="661"
             Background="#0A003A">

    <UserControl.Resources>
        <!-- Estilos Labels -->
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="GhostWhite"/>
            <Setter Property="FontFamily" Value="Montserrat"/>
        </Style>

        <!-- Estilos Base de Formulario -->
        <Style TargetType="{x:Type Control}" x:Key="BaseFormStyle">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="FontFamily" Value="Montserrat"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="DarkGray"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="{x:Null}"/>
            <Setter Property="Width" Value="252"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>

        <Style TargetType="TextBox" BasedOn="{StaticResource BaseFormStyle}"/>
        <Style TargetType="PasswordBox" BasedOn="{StaticResource BaseFormStyle}">
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="ComboBox" BasedOn="{StaticResource BaseFormStyle}">
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#1B1428"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>

    </UserControl.Resources>

    <Grid Background="#0A003A" Margin="0,0,10,0">

        <!-- LOGO -->
        <Image Source="/Images/TRACTOR_V2.png" 
               Width="120" 
               Height="100" 
               Margin="30,20,0,0" 
               HorizontalAlignment="Left" 
               VerticalAlignment="Top"/>

        <!-- TÍTULO -->
        <Label Content="Productos" 
               FontSize="28" 
               FontWeight="Bold" 
               Margin="170,30,0,0" 
               HorizontalAlignment="Left"
               VerticalAlignment="Top"
               Foreground="White"/>

        <Label Content="Completa el formulario para registrar o editar un producto"
               Foreground="#FF81969C" 
               FontSize="10" 
               Margin="170,65,0,0"
               HorizontalAlignment="Left"
               VerticalAlignment="Top"/>

        <!-- CONTENEDOR PRINCIPAL -->
        <Grid Margin="30,120,30,80">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- COLUMNA IZQUIERDA - DATOS BÁSICOS -->
            <StackPanel Grid.Column="0" Orientation="Vertical">

                <Label Content="ID del Producto"/>
                <TextBox x:Name="txtIdProducto" 
                         Width="252" 
                         IsReadOnly="True"
                         Background="#1B1428"
                         Foreground="White"
                         BorderBrush="DarkGray"
                         BorderThickness="1"
                         Height="28"
                         Margin="0,0,0,15"/>

                <Label Content="Nombre del Producto"/>
                <TextBox x:Name="txtNombreProducto" Width="252"/>

                <Label Content="Precio"/>
                <TextBox x:Name="txtPrecio" Width="252"/>

                <Label Content="Estatus"/>
                <CheckBox x:Name="chkEstatus" 
                          Content="Activo" 
                          Foreground="White"
                          FontFamily="Montserrat"
                          FontSize="13"
                          Margin="0,0,0,15"/>

            </StackPanel>

            <!-- COLUMNA CENTRAL - DETALLES DEL PRODUCTO -->
            <StackPanel Grid.Column="1" Orientation="Vertical" Margin="30,0,0,0">

                <Label Content="Detalles del Producto" 
                       FontSize="16" 
                       FontWeight="SemiBold" 
                       Margin="0,0,0,10"
                       Foreground="White"/>

                <Label Content="Marca"/>
                <ComboBox x:Name="cmbMarca" 
                          Width="252" 
                          Foreground="Black" 
                          SelectedIndex="0"/>

                <Label Content="Tipo de Producto"/>
                <ComboBox x:Name="cmbTipoProducto" 
                          Width="252" 
                          Foreground="Black" 
                          SelectedIndex="0"/>

            </StackPanel>

        </Grid>

        <!-- BOTONES INFERIORES -->
        <StackPanel Orientation="Horizontal" 
                    Margin="30,0,0,30" 
                    HorizontalAlignment="Left"
                    VerticalAlignment="Bottom">

            <Button x:Name="btnBuscar" 
                    Content="Buscar" 
                    Width="100" 
                    Height="35"
                    Background="#2C2545" 
                    Foreground="White"
                    FontFamily="Montserrat"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Cursor="Hand"
                    Margin="0,0,10,0" 
                    Click="btnBuscar_Click"/>

            <Button x:Name="btnEliminar" 
                    Content="Borrar" 
                    Width="100" 
                    Height="35"
                    Background="#8B2C4E" 
                    Foreground="White"
                    FontFamily="Montserrat"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="btnEliminar_Click"/>
        </StackPanel>

        <Button x:Name="btnCancelar"
Content="Cancelar"
Width="130"
Height="45"
FontSize="16"
FontWeight="Bold"
Margin="0,0,180,30"
HorizontalAlignment="Right"
VerticalAlignment="Bottom"
Background="#2C2545"
Foreground="White"
FontFamily="Montserrat"
BorderThickness="0"
Cursor="Hand"
Click="btnCancelar_Click"/>
        
        <Button x:Name="btnGuardar"
                Content="Guardar"
                Width="130"
                Height="45"
                FontSize="16"
                FontWeight="Bold"
                Margin="0,0,30,30"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Background="#2C2545"
                Foreground="White"
                FontFamily="Montserrat"
                BorderThickness="0"
                Cursor="Hand"
                Click="btnGuardar_Click"/>

    </Grid>
</UserControl>