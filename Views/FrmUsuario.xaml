<Window x:Class="AppTaller.Views.FrmUsuario"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AppTaller.Views"
        mc:Ignorable="d"
        Title="FrmUsuario" Height="450" Width="800"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        AllowsTransparency="True"
        MouseDown="Window_MouseDown" Loaded="Window_Loaded"
        >

    <Border
     CornerRadius="20"
     BorderBrush="DarkSlateGray"
     BorderThickness="5">

        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#121212" Offset="0"/>
                <GradientStop Color="#1E3A5F" Offset="0.6"/>
            </LinearGradientBrush>
        </Border.Background>

        <Grid MouseDown="Grid_MouseDown">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#121212" Offset="0"/>
                    <GradientStop Color="#1E3A5F" Offset="0.6"/>
                </LinearGradientBrush>
            </Grid.Background>
            <Label Content="Crear Usuario" HorizontalAlignment="Left" Margin="133,10,0,0" VerticalAlignment="Top" Foreground="GhostWhite" FontSize="36" FontWeight="Bold"/>
            <Label Content="Completa el formulario para crear el usuario " HorizontalAlignment="Left" Margin="133,57,0,0" VerticalAlignment="Top" Foreground="#FF81969C" Width="205" RenderTransformOrigin="0.641,0.458" FontSize="10"/>
            <Label Content="Nombre de Usuario" HorizontalAlignment="Left" Margin="133,90,0,0" VerticalAlignment="Top" Foreground="GhostWhite" FontSize="16"/>
            <Label Content="Telefono del Usuario" HorizontalAlignment="Left" Margin="500,90,0,0" VerticalAlignment="Top" Foreground="GhostWhite" FontSize="16"/>
            <Label Content="Correo electronico" HorizontalAlignment="Left" Margin="133,158,0,0" VerticalAlignment="Top" Foreground="GhostWhite" FontSize="16"/>
            <Label Content="Contraseña" HorizontalAlignment="Left" Margin="133,222,0,0" VerticalAlignment="Top" Foreground="GhostWhite" FontSize="16"/>
            <Label Content="Confirmar Contraseña" HorizontalAlignment="Left" Margin="133,286,0,0" VerticalAlignment="Top" Foreground="GhostWhite" FontSize="16"/>
            <TextBox x:Name="txtNombre" HorizontalAlignment="Left" Margin="133,133,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="252"
                
FontSize="13"
FontWeight="Medium"
FontFamily="Montserrat"
Foreground="White"
CaretBrush="LightGray"
BorderBrush="DarkGray"
BorderThickness="0,0,0,2"
Height="28"
VerticalContentAlignment="Center" Background="{x:Null}"
/>
            <TextBox x:Name="txtCorreo" HorizontalAlignment="Left" Margin="133,194,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="252"
                
            FontSize="13"
            FontWeight="Medium"
            FontFamily="Montserrat"
            Foreground="White"
            CaretBrush="LightGray"
            BorderBrush="DarkGray"
            BorderThickness="0,0,0,2"
            Height="28"
            VerticalContentAlignment="Center" Background="{x:Null}"
/>
            <Image Source ="/Images/TRACTOR_V2.png" Stretch="Fill" Height="100" Width="106" Margin="10,10,684,324"/>
            <PasswordBox x:Name="txtContrasena" HorizontalAlignment="Left" Margin="133,253,0,0" VerticalAlignment="Top" Width="252"
                     
                     FontSize="13"
FontWeight="Medium"
FontFamily="Montserrat"
Foreground="White"
CaretBrush="LightGray"
BorderBrush="DarkGray"
BorderThickness="0,0,0,2"
Height="28"
VerticalContentAlignment="Center" Background="{x:Null}"

                     />
            <PasswordBox x:Name="txtContrasena2"  HorizontalAlignment="Left" Margin="133,320,0,0" VerticalAlignment="Top" Width="252"
                     
            FontSize="13"
            FontWeight="Medium"
            FontFamily="Montserrat"
            Foreground="White"
            CaretBrush="LightGray"
            BorderBrush="DarkGray"
            BorderThickness="0,0,0,2"
            Height="28"
            VerticalContentAlignment="Center" Background="{x:Null}"

                     />
            <Button x:Name="btnGuardar" Content="GUARDAR" HorizontalAlignment="Left" Margin="466,347,0,0" VerticalAlignment="Top" Background="#FFD6A04A" Foreground="GhostWhite" FontWeight="ExtraBold" Width="96" Height="31" Click="Button_Click"/>
            <Button Content="CANCELAR" HorizontalAlignment="Left" Margin="621,347,0,0" VerticalAlignment="Top" Background="#FFD6504A" Foreground="GhostWhite" FontWeight="ExtraBold" Width="96" Height="31" Click="Button_Click_1"/>
            <TextBox x:Name="txtTelefono" HorizontalAlignment="Left" Margin="466,133,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="252"
                
            FontSize="13"
            FontWeight="Medium"
            FontFamily="Montserrat"
            Foreground="White"
            CaretBrush="LightGray"
            BorderBrush="DarkGray"
            BorderThickness="0,0,0,2"
            Height="28"
            VerticalContentAlignment="Center" Background="{x:Null}"
/>
            <CheckBox x:Name="estatus"  Content="Vigente" Margin="501,194,221,222" Foreground="White" FontFamily="Montserrat"/>
            <Label Content="Estatus" HorizontalAlignment="Left" Margin="500,158,0,0" VerticalAlignment="Top" Foreground="GhostWhite" FontSize="16"
               FontFamily="Montserrat"/>
            <ComboBox x:Name="idRol" 
          DisplayMemberPath="Id" 
          SelectedValuePath="Id"
                      Height="20"
                      Width="140"
                      Margin="487,253,163,167"/>
            <Label Content="Id del rol" HorizontalAlignment="Left" Margin="500,222,0,0" VerticalAlignment="Top" Foreground="GhostWhite" FontSize="16"
            FontFamily="Montserrat"/>
            <Button x:Name="btnBuscar"
                 
                    HorizontalAlignment="Left"
                    Margin="661,234,0,0" 
                    VerticalAlignment="Top"
                    Background="Transparent"
                    BorderThickness="0" Height="47" Width="57" Click="btnBuscar_Click"
                    >
                <Image Source="/Images/buscar.png" Stretch="Uniform" Height="35" Width="35" />
            </Button>
            <Label Content="Numero de usuario" HorizontalAlignment="Left" Margin="461,32,0,0" VerticalAlignment="Top" Foreground="GhostWhite" FontSize="16"/>
            <TextBox x:Name="txtId" HorizontalAlignment="Left" Margin="466,63,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="252"
                
                FontSize="13"
                FontWeight="Medium"
                FontFamily="Montserrat"
                Foreground="White"
                CaretBrush="LightGray"
                BorderBrush="DarkGray"
                BorderThickness="0,0,0,2"
                Height="28"
                VerticalContentAlignment="Center" Background="{x:Null}"
/>
            <Button x:Name="btnBorrar"
                 
                HorizontalAlignment="Left"
                Margin="660,287,0,0" 
                VerticalAlignment="Top"
                Background="Transparent"
                BorderThickness="0" Height="47" Width="57" Click="btnBorrar_Click"
                    >
                <Image Source="/Images/borrar.png" Stretch="Uniform" Height="35" Width="35" />
            </Button>


        </Grid>
    </Border>
</Window>